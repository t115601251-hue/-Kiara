	<title>boardmix</title>
	<script>
		var _SkmAppObj = {}
		var globalThis = globalThis || this;
		window.__global_env__ = {
			hashVersion: "5de7c7d5edfea78def6f47476f6fdae91a3ff15bdbde6fad",
			HTTP_API_BASE: "https://api.boardmix.cn",
			HTTP_CDN_BASE: "https://cdnhw.boardmix.cn",
			DEPLOY_TYPE: "www",
			SENTRY: undefined,
			EXTERNAL: undefined,
			HTTP_SERVER_BASE: "",
			UI_LANG: ""
		}
		window.__toCdnUrl = function(fileName) {
			return window.__global_env__.HTTP_CDN_BASE + fileName;
		}
		window.runtimeTool = {};
	</script>
	<script>
		(function () {
                try {
                    var theme = localStorage.getItem("theme");
                    if (!theme) {
                        return;
                    }
                    var isDark =
                        theme === "dark" ||
                        theme === "darkGrey" ||
                        (theme === "auto" &&
                            window.matchMedia &&
                            window.matchMedia("(prefers-color-scheme: dark)")
                                .matches);
                    if (isDark) {
                        document.documentElement.setAttribute(
                            "data-skeleton-mode",
                            "dark"
                        );
						// 同步在theme.ts中修改
						document.documentElement.setAttribute(
							"data-theme-mode",
							"dark"
						);
                    }
                } catch (e) {
                    // ignore
                }
            })();
	</script>
