<script>
	function openHomeSkeletonWithMenu() {
		document.querySelector(".ed-skeleton-page").style.display = "flex";
	}

	function openHomeSkeletonWithoutMenu() {
		document.querySelector(".ed-skeleton-page").style.display = "flex";
	}
	
	function openDialogSkeleton() {
		document.querySelector(".ed-skeleton-dialog").style.display = "flex";
	}

	function openEditPageSkeleton() {
		document.querySelector(".ed-skeleton-edit-page").style.display =
			"flex";
	}

	const DialogPathName = /\/app\/(dialog)/
	const WithMenuPathName = /\/app\/(team|my-folder|favorite)/
	const WithoutMenuPathName = /\/app\/(trash|template|recent-file|home|material)/
	const EditPagePathName = /\/app\/(editor|embed)/
	if (WithMenuPathName.test(location.pathname)) {
		openHomeSkeletonWithMenu()
	} else if (location.pathname === "/app/" || WithoutMenuPathName.test(location.pathname)) {
		openHomeSkeletonWithoutMenu()
	} else if (DialogPathName.test(location.pathname)){
		openDialogSkeleton()
	} else if (EditPagePathName.test(location.pathname)) {
		openEditPageSkeleton()
	}
</script>
