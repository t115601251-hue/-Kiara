<script src="/app/vendor/cas-client-bosyun.www.js?v=20251226"></script>


<script>
	const serverBase = window.__global_env__.HTTP_SERVER_BASE;
	const prefix = serverBase
		? serverBase.replace(/^\//, "").replace(/\//g, "-")
		: "";
	let isStorageSupport = true;

	try {
		localStorage.getItem("check");
	} catch {
		isStorageSupport = false;
	}

	const _getItem = Storage.prototype.getItem;
	const _setItem = Storage.prototype.setItem;
	const _removeItem = Storage.prototype.removeItem;
	const storageCache = { local: {}, session: {} };
	Storage.prototype.getItem = function (_key) {
		const key = prefix ? `${ prefix }-${ _key }` : _key;
		if (!isStorageSupport) {
			if (this === window.localStorage) {
				return key in storageCache.local ? storageCache.local[key] : null;
			} else if (this === window.sessionStorage) {
				return key in storageCache.session
					? storageCache.session[key]
					: null;
			}
		}
		return _getItem.apply(this, [key]);
	};

	Storage.prototype.setItem = function (_key, value) {
		const key = prefix ? `${ prefix }-${ _key }` : _key;
		if (!isStorageSupport) {
			if (this === window.localStorage) {
				storageCache.local[key] = value;
				return;
			} else if (this === window.sessionStorage) {
				storageCache.session[key] = value;
				return;
			}
		}
		_setItem.apply(this, [key, value]);
	};

	Storage.prototype.removeItem = function (_key) {
		const key = prefix ? `${ prefix }-${ _key }` : _key;
		if (!isStorageSupport) {
			if (this === window.localStorage) {
				delete storageCache.local[key];
				return;
			} else if (this === window.sessionStorage) {
				delete storageCache.session[key];
				return;
			}
		}
		_removeItem.apply(this, arguments);
	};
	const deployType = window.__global_env__.DEPLOY_TYPE;
	const isSensorsSupport =
		["www", "sdk", "oversea", "sdk-oversea"].includes(deployType);

	if (isSensorsSupport && bosyunSensors.sensorsInit && isStorageSupport) {
		const isOversea =
			deployType === "oversea" || deployType === "sdk-oversea";
		const prodList = isOversea
			? [
				"sdk.boardmix.com",
				"sdk-pre.boardmix.com",
				"boardmix.com",
				"pre.boardmix.com"
			]
			: [
				"sdk.boardmix.cn",
				"sdk-pre.boardmix.cn",
				"boardmix.cn",
				"pre.boardmix.cn"
			];
		const isProd = prodList.includes(location.host);
		const env = isOversea
			? isProd
				? "oversea"
				: "oversea-test"
			: isProd
				? "www"
				: "www-test";
		if (deployType === "oversea") {
			const isMarketAccpet =
				$bmCookie.getCookieAcceptStatus("marketingCookies") !==
				false;
			isMarketAccpet && bosyunSensors.sensorsInit(env, "board", bosyunSensors.StorageAPI.cookie);
		} else {
			bosyunSensors.sensorsInit(env, "board", bosyunSensors.StorageAPI.cookie);
		}
		window.sensors = window.sensorsDataAnalytic201505;
	}
</script>
