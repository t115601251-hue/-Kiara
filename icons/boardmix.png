		if (true) {
			const googleEnabled = !!window.dataLayer;
			const isProdSite = ["boardmix.cn", "boardmix.com"].includes(location.host);
			if (!googleEnabled) {
				if (!isProdSite) {
					alert("google tag manager may be broken!");
				}
			}
		}
	</script>

