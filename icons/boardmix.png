	<!-- INJECT_OFFLINE_PLACEHOLDER -->
	<style>
		:root {
			--skm-skeleton-bg: rgb(255, 255, 255);
			--skm-skeleton-side-bg: #f7f7f9;
			--skm-skeleton-panel-bg: #fff;
			--skm-skeleton-block-bg: #f7f7f9;
			--skm-skeleton-block-bg-2: #f3f3f5;
			--skm-skeleton-image-bg: #f4f4f6;
			--skm-skeleton-border: rgba(6, 6, 31, 0.09);
			--skm-skeleton-panel-border: rgba(18, 17, 42, 0.07);
			--skm-skeleton-separator: rgba(18, 17, 42, 0.09);
		}

		html[data-skeleton-mode="dark"] {
			--skm-skeleton-bg: #19191a;
			--skm-skeleton-side-bg: #1f1f20;
			--skm-skeleton-panel-bg: #1f1f20;
			--skm-skeleton-block-bg: #2a2a2b;
			--skm-skeleton-block-bg-2: #242425;
			--skm-skeleton-image-bg: #232324;
			--skm-skeleton-border: rgba(255, 255, 255, 0.12);
			--skm-skeleton-panel-border: rgba(255, 255, 255, 0.12);
			--skm-skeleton-separator: rgba(255, 255, 255, 0.12);
		}

		body {
			overflow: hidden;
			margin: 0;
			padding: 0;
		}

		.ed-skeleton-dialog {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 100vw;
			height: 100vh;
			background: var(--skm-skeleton-bg);
		}

		.ed-skeleton-dialog---img {
			width: 205px;
			height: 54px;
		}

		.ed-skeleton-page {
			width: 100vw;
			height: 100vh;
			display: flex;
			background: var(--skm-skeleton-bg);
		}

		.ed-skeleton-page--left {
			display: flex;
			background: var(--skm-skeleton-side-bg);
		}

		.ed-skeleton-page--left-panel {
			padding: 0 16px;
			width: 300px;
			border-right: 1px solid var(--skm-skeleton-panel-border);
			box-sizing: border-box;
			display: flex;
			flex-direction: column;
			background-color: var(--skm-skeleton-panel-bg);
		}

		.ed-skeleton-page--left-panel-logo {
			display: flex;
			align-items: center;
			width: 100%;
			height: 52px;
		}

		.ed-skeleton-page--left-panel-icon {
			display: inline-block;
			height: 28px;
		}

		.ed-skeleton-page--left-panel-search {
			height: 28px;
			margin: 6px 0 18px 0;
			border-radius: 8px;
			background-color: var(--skm-skeleton-block-bg);
		}

		.ed-skeleton-page--left-panel-item {
			display: flex;
			align-items: center;
			gap: 7px;
			margin-bottom: 32px;
		}

		.ed-skeleton-page--left-panel-item-lf {
			width: 16px;
			height: 16px;
			background: var(--skm-skeleton-block-bg);
			border-radius: 2px;
		}
		.ed-skeleton-page--left-panel-item-rt {
			width: 132px;
			height: 16px;
			background: var(--skm-skeleton-block-bg);
			border-radius: 4px;
		}

		.ed-skeleton-page--left-panel-separator {
			height: 1px;
			padding: 0 8px;
			background: var(--skm-skeleton-separator);
			margin-bottom: 24px;
		}

		.ed-skeleton-page--right {
			flex: 1;
			display: flex;
			flex-direction: column;
			padding: 0 40px;
		}

		.ed-skeleton-page--right-header {
			display: flex;
			height: 64px;
			display: flex;
			margin-bottom: 27px;
			justify-content: space-between;
			align-items: center;
		}

		.ed-skeleton-page--right-header-left {
			width: 240px;
			height: 16px;
			background: var(--skm-skeleton-block-bg);
			border-radius: 4px;
		}

		.ed-skeleton-page--right-header-right {
			display: none;
			align-items: center;
		}

		.ed-skeleton-page--right-header-msg {
			width: 88px;
			height: 16px;
			margin-right: 24px;
			background: var(--skm-skeleton-block-bg);
			border-radius: 4px;
		}

		.ed-skeleton-page--right-header-avatar {
			width: 24px;
			height: 24px;
			border-radius: 50%;
			background: var(--skm-skeleton-block-bg);
		}

		.ed-skeleton-page--right-subtitle {
			width: 88px;
			height: 16px;
			margin-bottom: 16px;
			background: var(--skm-skeleton-block-bg);
			border-radius: 4px;
		}

		.ed-skeleton-page--right-separator {
			height: 1px;
			width: 100%;
			background: var(--skm-skeleton-separator);
			margin-bottom: 32px;
		}

		.ed-skeleton-page--right-content {
			flex: 1;
		}

		.ed-skeleton-page--right-content {
			display: flex;
			flex-direction: column;
		}

		.ed-skeleton-page--right-content-top {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(242px, 1fr));
			grid-template-rows: repeat(1);
			overflow: hidden;
			height: 212px;
			gap: 24px;
			margin-bottom: 24px;
		}

		.ed-skeleton-page--right-content-top-item {
			max-width: 280px;
			height: 209px;
			border-radius: 8px;
			display: flex;
			flex-direction: column;
			background: var(--skm-skeleton-panel-bg);
			border: 1px solid var(--skm-skeleton-border);
			border-radius: 8px;
		}

		.ed-skeleton-page--content-item-img {
			flex: 1;
			border-radius: 8px 8px 0 0;
			background: var(--skm-skeleton-image-bg);
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.ed-skeleton-page--content-item-img-content {
			width: 135px;
			height: 36px;
		}

		.ed-skeleton-page--content-item-name {
			margin: 14px 0 8px 12px;
			background: var(--skm-skeleton-block-bg);
			height: 16px;
			width: 120px;
			border-radius: 2px;
		}

		.ed-skeleton-page--content-item-info {
			margin-left: 12px;
			background: var(--skm-skeleton-block-bg-2);
			height: 16px;
			width: 60px;
			border-radius: 2px;
			margin-bottom: 20px;
		}

		.ed-skeleton-page--content-item-back {
			height: 74px;
		}

		.ed-skeleton-edit-page {
			width: 100vw;
			height: 100vh;
			background: var(--skm-skeleton-bg);
		}
	</style>
	


